{
    "name": "terraform-cicd",
    "version": "0.1.0",
    "description": "Devbox plugin for Terraform with integrated linting, security scanning, and documentation generation.",
    "packages": [
        "trivy@latest",
        "terraform-docs@latest",
        "tflint@latest"
    ],
    "env": {
      "TFCICD_SCRIPTS": "{{.Virtenv}}",
      "TFCICD_CONFIG": "{{.DevboxDir}}"
    },
    "create_files": {
        "{{ .Virtenv }}/functions.sh": "scripts/functions.sh",
        "{{ .Virtenv }}/plan-and-apply.sh": "scripts/plan-and-apply.sh",
        "{{ .Virtenv }}/plan.sh": "scripts/plan.sh",
        "{{ .Virtenv }}/apply.sh": "scripts/apply.sh",
        "{{ .Virtenv }}/check-quality.sh": "scripts/check-quality.sh",
        "{{ .Virtenv }}/test.sh": "scripts/test.sh",
        "{{ .DevboxDir }}/.tflint.hcl": "config/.tflint.hcl",
        "{{ .DevboxDir }}/trivy.yaml": "config/trivy.yaml"
    },
    "shell": {
        "init_hook": [
            "echo 'Welcome to devbox plugin terraform-cicd!'",
            "chmod +x $TFCICD_SCRIPTS/*.sh"
        ],
        "scripts": {
            "plan-and-apply": [
                "$TFCICD_SCRIPTS/plan-and-apply.sh \"$@\""
            ],
            "plan": [
                "$TFCICD_SCRIPTS/plan.sh \"$@\""
            ],
            "apply": [
                "$TFCICD_SCRIPTS/apply.sh \"$@\""
            ],
            "check-quality": [
                "$TFCICD_SCRIPTS/check-quality.sh \"$@\""
            ],
            "test": [
                "$TFCICD_SCRIPTS/test.sh \"$@\""
            ]
        }
    },
    "include": []
}